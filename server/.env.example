# Copy to /etc/nest-api.env on the VPS (the deploy script creates a starter
# automatically if it's missing). Never commit the real file.

PORT=8091
NEST_DB=/var/lib/nest-api/nest.db
APP_URL=https://nestwithin.mrrado.com
PUBLIC_URL=https://nestwithin.mrrado.com

# Generated on first deploy; keep it secret and stable.
JWT_SECRET=change-me

# Password for the /nirvana admin console (generated on first deploy).
ADMIN_PASSWORD=change-me

# ── Mailgun (leave blank to run in STUB mode: emails are logged, not sent) ──
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=US
MAIL_FROM=The Nest <no-reply@nestwithin.mrrado.com>
